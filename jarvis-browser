#!/usr/bin/env bash
set -euo pipefail

SERVICE_NAME="jarvis-chrome.service"
DEBUG_URL="${JARVIS_CHROME_STATUS_URL:-http://127.0.0.1:9222/json/version}"
WAIT_SECONDS="${JARVIS_CHROME_WAIT_SECONDS:-15}"

usage() {
  echo "usage: jarvis-browser {start|stop|restart|status}" >&2
}

is_active() {
  systemctl --user is-active --quiet "$SERVICE_NAME"
}

cdp_ready() {
  curl -fsS --max-time 1 "$DEBUG_URL" >/dev/null 2>&1
}

wait_for_cdp() {
  local i
  for ((i=0; i<WAIT_SECONDS; i++)); do
    if cdp_ready; then
      return 0
    fi
    sleep 1
  done
  return 1
}

print_status() {
  local active="false"
  local cdp="false"
  local main_pid=""

  if is_active; then
    active="true"
    main_pid="$(systemctl --user show -p MainPID --value "$SERVICE_NAME" 2>/dev/null || true)"
  fi

  if cdp_ready; then
    cdp="true"
  fi

  printf '{"service_active":%s,"cdp_ready":%s,"main_pid":%s,"debug_url":"%s"}\n' \
    "$active" \
    "$cdp" \
    "${main_pid:-null}" \
    "$DEBUG_URL"
}

case "${1:-}" in
  start)
    systemctl --user start "$SERVICE_NAME"
    if wait_for_cdp; then
      print_status
    else
      echo "Service started but DevTools did not become ready within ${WAIT_SECONDS}s" >&2
      print_status
      exit 1
    fi
    ;;
  stop)
    systemctl --user stop "$SERVICE_NAME"
    print_status
    ;;
  restart)
    systemctl --user restart "$SERVICE_NAME"
    if wait_for_cdp; then
      print_status
    else
      echo "Service restarted but DevTools did not become ready within ${WAIT_SECONDS}s" >&2
      print_status
      exit 1
    fi
    ;;
  status)
    print_status
    ;;
  *)
    usage
    exit 2
    ;;
esac
